# Puerto del servidor
PORT=3000

# JWT Secret - Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_secure_jwt_secret_here

# Base de datos PostgreSQL
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/MA_USALADB

# Google OAuth - Obtener de: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Orígenes permitidos para CORS (separados por comas)
ALLOWED_ORIGINS=http://localhost:3173,http://localhost:5173,https://tudominio.com

# Contraseña para datos de prueba (seed)
SEED_ADMIN_PASSWORD=cambiar_en_produccion
SEED_DOCENTE_PASSWORD=cambiar_en_produccion
SEED_USUARIO_PASSWORD=cambiar_en_produccion

# Entorno
NODE_ENV=development

# Correo SMTP (para recuperación de contraseña)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@usala.com

# URL del frontend (para enlaces de recuperación)
FRONTEND_URL=http://localhost:5173
